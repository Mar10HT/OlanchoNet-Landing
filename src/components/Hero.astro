---
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#0d1421]"
>
  <!-- Background grid pattern -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(#ffffff 1px, transparent 1px), linear-gradient(90deg, #ffffff 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <!-- Radial glow from brand blue -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(0,118,187,0.18) 0%, transparent 70%);"
  ></div>

  <!-- Green accent dot top-right -->
  <div
    class="absolute top-1/4 right-1/4 w-96 h-96 rounded-full opacity-10 blur-3xl"
    style="background: #4EB648;"
  ></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center pt-20">
    <!-- Eyebrow -->
    <p class="text-[#4EB648] text-sm font-semibold tracking-[0.2em] uppercase mb-6">
      Departamento de Olancho, Honduras
    </p>

    <!-- Heading -->
    <h1 class="text-white font-display font-black leading-none mb-8">
      <span class="block text-5xl sm:text-6xl lg:text-8xl tracking-tight">
        Internet que
      </span>
      <span
        class="block text-5xl sm:text-6xl lg:text-8xl tracking-tight mt-2"
        style="color: #4EB648;"
      >
        conecta Olancho.
      </span>
    </h1>

    <!-- Subtext -->
    <p class="text-white/60 text-lg sm:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
      Llevamos conectividad de alta velocidad a hogares y empresas en 14 municipios
      del departamento. Fibra, inalámbrico, IPTV y soporte técnico local.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#servicios"
        class="px-8 py-3.5 text-white font-semibold text-sm tracking-wide rounded transition-all duration-200 hover:opacity-90 hover:scale-105"
        style="background: #0076BB;"
      >
        Ver servicios
      </a>
      <a
        href="#contacto"
        class="px-8 py-3.5 border border-white/30 text-white font-semibold text-sm tracking-wide rounded transition-all duration-200 hover:border-white/60 hover:bg-white/5"
      >
        Contactar
      </a>
    </div>

    <!-- Stats -->
    <div class="mt-20 grid grid-cols-3 gap-8 max-w-lg mx-auto border-t border-white/10 pt-10">
      <div>
        <div class="text-3xl font-black text-white">14</div>
        <div class="text-white/40 text-xs tracking-wider uppercase mt-1">Municipios</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white">10+</div>
        <div class="text-white/40 text-xs tracking-wider uppercase mt-1">Años</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white">6</div>
        <div class="text-white/40 text-xs tracking-wider uppercase mt-1">Servicios</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 bg-white/20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full bg-white/60 animate-bounce"></div>
    </div>
  </div>
</section>
