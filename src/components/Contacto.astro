---
---

<section id="contacto" class="py-24 lg:py-32 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-16">
      <p class="text-brand-blue text-xs font-semibold tracking-[0.25em] uppercase mb-4">
        Hablemos
      </p>
      <h2 class="font-display font-black text-4xl lg:text-5xl text-gray-900 tracking-tight leading-tight max-w-lg">
        Estamos listos para conectarte
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

      <!-- Contact info -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Teléfonos -->
        <div>
          <p class="text-xs font-semibold text-gray-400 tracking-widest uppercase mb-4">Teléfonos</p>
          <div class="space-y-3">
            <a
              href="tel:+50427854010"
              class="flex items-center gap-3 text-gray-700 hover:text-brand-blue transition-colors group"
            >
              <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 transition-colors group-hover:bg-blue-50" style="background: rgba(0,118,187,0.08);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.16 6.16l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/>
                </svg>
              </span>
              <span class="font-medium">+504 2785-4010</span>
            </a>
            <a
              href="tel:+50495015187"
              class="flex items-center gap-3 text-gray-700 hover:text-brand-blue transition-colors group"
            >
              <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 transition-colors group-hover:bg-blue-50" style="background: rgba(0,118,187,0.08);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.16 6.16l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/>
                </svg>
              </span>
              <span class="font-medium">+504 9501-5187</span>
            </a>
          </div>
        </div>

        <!-- Emails -->
        <div>
          <p class="text-xs font-semibold text-gray-400 tracking-widest uppercase mb-4">Correo electrónico</p>
          <div class="space-y-3">
            <a
              href="mailto:soporte@olanchonet.com"
              class="flex items-center gap-3 text-gray-700 hover:text-brand-blue transition-colors group"
            >
              <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(0,118,187,0.08);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <div>
                <div class="font-medium text-sm">soporte@olanchonet.com</div>
                <div class="text-gray-400 text-xs">Soporte técnico</div>
              </div>
            </a>
            <a
              href="mailto:ventas@olanchonet.com"
              class="flex items-center gap-3 text-gray-700 hover:text-brand-blue transition-colors group"
            >
              <span class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(0,118,187,0.08);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <div>
                <div class="font-medium text-sm">ventas@olanchonet.com</div>
                <div class="text-gray-400 text-xs">Planes y ventas</div>
              </div>
            </a>
          </div>
        </div>

        <!-- Horarios note -->
        <div class="pt-4 border-t border-gray-200">
          <p class="text-gray-400 text-sm leading-relaxed">
            Atención al cliente de lunes a sábado de 8:00 AM a 5:00 PM. Soporte técnico disponible todos los días.
          </p>
        </div>
      </div>

      <!-- Contact form -->
      <div class="lg:col-span-3 bg-white rounded-2xl p-8 lg:p-10 shadow-sm border border-gray-100">
        <h3 class="font-display font-bold text-xl text-gray-900 mb-6">Envíanos un mensaje</h3>

        <form class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="contacto-nombre" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                Nombre completo
              </label>
              <input
                id="contacto-nombre"
                type="text"
                name="nombre"
                placeholder="Tu nombre"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent transition-all"
                required
              />
            </div>
            <div>
              <label for="contacto-email" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                Correo electrónico
              </label>
              <input
                id="contacto-email"
                type="email"
                name="email"
                placeholder="tu@correo.com"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent transition-all"
                required
              />
            </div>
          </div>

          <div>
            <label for="contacto-telefono" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
              Teléfono
            </label>
            <input
              id="contacto-telefono"
              type="tel"
              name="telefono"
              placeholder="+504 0000-0000"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent transition-all"
            />
          </div>

          <div>
            <label for="contacto-servicio" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
              Servicio de interés
            </label>
            <select
              id="contacto-servicio"
              name="servicio"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:border-transparent transition-all bg-white"
            >
              <option value="">Seleccionar servicio...</option>
              <option>Internet Residencial</option>
              <option>Fibra Empresarial</option>
              <option>Enlaces Inalámbricos</option>
              <option>Diseño de Redes</option>
              <option>IPTV</option>
              <option>Instalaciones Eléctricas</option>
              <option>Otro</option>
            </select>
          </div>

          <div>
            <label for="contacto-mensaje" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
              Mensaje
            </label>
            <textarea
              id="contacto-mensaje"
              name="mensaje"
              rows="4"
              placeholder="Cuéntanos cómo podemos ayudarte..."
              class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent transition-all resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-3.5 text-white font-semibold text-sm tracking-wide rounded-lg transition-all duration-200 hover:opacity-90 hover:shadow-md"
            style="background: var(--color-brand-blue);"
          >
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  input:focus, select:focus, textarea:focus {
    ring-color: var(--color-brand-blue);
    border-color: var(--color-brand-blue);
    box-shadow: 0 0 0 2px rgba(0, 118, 187, 0.2);
  }
</style>
