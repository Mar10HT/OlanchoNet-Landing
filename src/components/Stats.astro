---
const stats = [
  { label: 'Clientes satisfechos', number: '+4,000', target: 4000, prefix: '+', suffix: '',  comma: true,  context: 'Red más grande de Olancho', color: 'var(--color-brand-blue)'  },
  { label: 'Crecimiento anual',    number: '+30%',   target: 30,   prefix: '+', suffix: '%', comma: false, context: 'Último año en clientes',    color: 'var(--color-brand-green)' },
  { label: 'Municipios nuevos',    number: '+2',     target: 2,    prefix: '+', suffix: '',  comma: false, context: 'Expansión en 2024',          color: 'var(--color-brand-blue)'  },
  { label: 'Años de experiencia',  number: '+10',    target: 10,   prefix: '+', suffix: '',  comma: false, context: 'Líderes en el mercado',      color: 'var(--color-brand-green)' },
];
---

<section id="stats" class="bg-brand-darker py-16">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {stats.map((s, i) => (
        <div
          class="reveal rounded-xl p-7"
          style={`background: var(--color-brand-dark); border-top: 4px solid ${s.color};`}
        >
          <p class="text-[10px] font-bold tracking-[0.15em] uppercase mb-4" style="color: rgba(255,255,255,0.5);">
            {s.label}
          </p>
          <p
            class="stat-num font-display font-black text-5xl text-white mb-2"
            data-target={s.target}
            data-prefix={s.prefix}
            data-suffix={s.suffix}
            data-comma={s.comma}
          >
            {s.number}
          </p>
          <p class="text-xs" style="color: rgba(255,255,255,0.35);">{s.context}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const section = document.getElementById('stats');
  if (section) {
    const nums = section.querySelectorAll<HTMLElement>('.stat-num');
    nums.forEach((el, i) => {
      const target = parseInt(el.dataset.target ?? '0');
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';
      const comma  = el.dataset.comma === 'true';
      const obj    = { value: 0 };

      gsap.to(obj, {
        value: target, duration: 1.4, delay: i * 0.08,
        ease: 'power3.out', snap: { value: 1 },
        onUpdate() {
          el.textContent = prefix + (comma ? obj.value.toLocaleString('es-HN') : String(obj.value)) + suffix;
        },
        scrollTrigger: { trigger: section, start: 'top 60%', once: true },
      });
    });
  }
</script>
