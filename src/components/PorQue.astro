---
const slides = [
  {
    // Right
    text: 'Red #1 de fibra óptica del departamento',
    desc: 'Infraestructura de última generación con velocidades simétricas y baja latencia en cada municipio.',
    // Left
    title: 'La red más avanzada de Olancho',
    sub:   'Fibra óptica de última generación',
    color: { bg: 'rgba(0,118,187,0.15)', fg: 'var(--color-brand-blue)', pulse: '0, 118, 187' },
    icon: `<circle cx="14" cy="6"  r="3" fill="var(--color-brand-blue)"/>
           <circle cx="4"  cy="22" r="3" fill="var(--color-brand-blue)"/>
           <circle cx="24" cy="22" r="3" fill="var(--color-brand-blue)"/>
           <line x1="14" y1="9"  x2="4"  y2="19" stroke="var(--color-brand-blue)" stroke-width="1.5" stroke-opacity="0.4"/>
           <line x1="14" y1="9"  x2="24" y2="19" stroke="var(--color-brand-blue)" stroke-width="1.5" stroke-opacity="0.4"/>
           <line x1="4"  y1="22" x2="24" y2="22" stroke="var(--color-brand-blue)" stroke-width="1.5" stroke-opacity="0.4"/>`,
  },
  {
    text: 'Más de 10 años de experiencia en el mercado',
    desc: 'Desde 2013 conectando hogares y empresas con conocimiento profundo del territorio y sus necesidades.',
    title: 'Experiencia que respalda',
    sub:   'Líderes en el mercado desde 2013',
    color: { bg: 'rgba(78,182,72,0.15)', fg: 'var(--color-brand-green)', pulse: '78, 182, 72' },
    icon: `<circle cx="14" cy="14" r="10" stroke="var(--color-brand-green)" stroke-width="1.5" fill="none"/>
           <line x1="14" y1="14" x2="14" y2="7"  stroke="var(--color-brand-green)" stroke-width="1.8" stroke-linecap="round"/>
           <line x1="14" y1="14" x2="18" y2="17" stroke="var(--color-brand-green)" stroke-width="1.8" stroke-linecap="round"/>
           <circle cx="14" cy="14" r="1.5" fill="var(--color-brand-green)"/>`,
  },
  {
    text: 'Personal profesional y capacitado',
    desc: 'Equipo técnico certificado disponible para instalaciones, mantenimiento y soporte técnico en sitio.',
    title: 'Equipo siempre disponible',
    sub:   'Soporte técnico local en sitio',
    color: { bg: 'rgba(0,118,187,0.15)', fg: 'var(--color-brand-blue)', pulse: '0, 118, 187' },
    icon: `<circle cx="10" cy="8" r="3.5" fill="none" stroke="var(--color-brand-blue)" stroke-width="1.5"/>
           <circle cx="20" cy="8" r="3.5" fill="none" stroke="var(--color-brand-blue)" stroke-width="1.5"/>
           <path d="M3 22c0-4 3-6 7-6s7 2 7 6" stroke="var(--color-brand-blue)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
           <path d="M20 16c3 0 5 2 5 6" stroke="var(--color-brand-blue)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-opacity="0.5"/>`,
  },
  {
    text: 'En constante expansión',
    desc: '+2 municipios incorporados en 2024. Seguimos creciendo para llevar conectividad a más comunidades.',
    title: 'Creciendo con Olancho',
    sub:   '+2 municipios nuevos en 2024',
    color: { bg: 'rgba(78,182,72,0.15)', fg: 'var(--color-brand-green)', pulse: '78, 182, 72' },
    icon: `<path d="M4 20 L14 8 L20 14 L26 4" stroke="var(--color-brand-green)" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
           <path d="M20 4 L26 4 L26 10"       stroke="var(--color-brand-green)" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];
---

<section id="porque" class="bg-brand-dark py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-6 items-stretch">

      <!-- Left panel -->
      <div
        class="reveal rounded-2xl p-10 flex flex-col justify-between min-h-[280px] overflow-hidden"
        style="background: var(--color-brand-darker);"
      >
        <!-- Icon slot -->
        <div class="relative w-14 h-14">
          {slides.map((s, i) => (
            <div
              class="left-icon absolute inset-0 rounded-full flex items-center justify-center"
              data-index={i}
              data-pulse={s.color.pulse}
              style={`background: ${s.color.bg}; opacity: ${i === 0 ? 1 : 0};`}
            >
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"
                set:html={s.icon}
              />
            </div>
          ))}
        </div>

        <!-- Text slot -->
        <div class="relative mt-8" style="min-height: 88px;">
          {slides.map((s, i) => (
            <div
              class="left-text absolute inset-x-0 top-0"
              data-index={i}
              style={`opacity: ${i === 0 ? 1 : 0};`}
            >
              <h3 class="font-display font-black text-3xl text-white leading-tight mb-3">
                {s.title}
              </h3>
              <p class="text-sm" style={`color: ${s.color.fg}; opacity: 0.75;`}>{s.sub}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right panel -->
      <div class="reveal flex flex-col justify-center py-4 lg:pl-8">
        <h2 class="font-display font-black text-4xl lg:text-5xl text-white tracking-tight mb-10">
          ¿Por qué elegirnos?
        </h2>

        <!-- Carousel slot -->
        <div id="porque-carousel" class="relative" style="min-height: 112px;">
          {slides.map((s, i) => (
            <div
              class="carousel-item absolute inset-x-0 top-0"
              data-index={i}
              style={`opacity: ${i === 0 ? 1 : 0}; pointer-events: ${i === 0 ? 'auto' : 'none'};`}
            >
              <div class="flex items-start gap-4 mb-3">
                <span
                  class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-[11px] font-bold mt-0.5"
                  style={`background: ${s.color.bg}; color: ${s.color.fg};`}
                >
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-white font-semibold text-base leading-snug">{s.text}</span>
              </div>
              <p class="text-sm leading-relaxed pl-[52px]" style="color: rgba(255,255,255,0.38);">{s.desc}</p>
            </div>
          ))}
        </div>

        <!-- Progress bar -->
        <div class="mt-8 h-px rounded overflow-hidden" style="background: rgba(255,255,255,0.07);">
          <div id="porque-progress" class="h-full rounded w-0" style="background: var(--color-brand-blue); opacity: 0.6;"></div>
        </div>

        <!-- Dot indicators -->
        <div class="flex gap-2.5 mt-4" aria-hidden="true">
          {slides.map((s, i) => (
            <div
              class="porque-dot rounded-full"
              data-index={i}
              style={`width: ${i === 0 ? '20px' : '6px'}; height: 6px; background: ${i === 0 ? s.color.fg : 'rgba(255,255,255,0.15)'};`}
            ></div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    .left-icon, .left-text { position: relative !important; opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const carousel = document.getElementById('porque-carousel');
  const progress = document.getElementById('porque-progress');
  const dots     = document.querySelectorAll<HTMLElement>('.porque-dot');
  const reduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const DOT_COLORS = [
    'var(--color-brand-blue)',
    'var(--color-brand-green)',
    'var(--color-brand-blue)',
    'var(--color-brand-green)',
  ];

  if (carousel) {
    const rightItems = carousel.querySelectorAll<HTMLElement>('.carousel-item');
    const leftIcons  = document.querySelectorAll<HTMLElement>('.left-icon');
    const leftTexts  = document.querySelectorAll<HTMLElement>('.left-text');
    let current = 0;

    // Active icon pulse animation
    let pulseKill: gsap.core.Tween | null = null;
    function startPulse(index: number) {
      if (pulseKill) pulseKill.kill();
      const icon = leftIcons[index];
      const rgb  = icon.dataset.pulse ?? '0,118,187';
      pulseKill = gsap.to(icon, {
        boxShadow: `0 0 0 10px rgba(${rgb}, 0)`,
        duration: 1.5,
        ease: 'power2.out',
        repeat: -1,
        repeatDelay: 1.5,
        onRepeat() {
          gsap.set(icon, { boxShadow: `0 0 0 0 rgba(${rgb}, 0.35)` });
        },
      });
    }

    function slideOut(el: HTMLElement) {
      gsap.to(el, {
        opacity: 0, y: -14, duration: 0.3, ease: 'power2.in',
        onComplete: () => gsap.set(el, { y: 0, pointerEvents: 'none' }),
      });
    }

    function slideIn(el: HTMLElement, fromBelow = true) {
      gsap.fromTo(el,
        { opacity: 0, y: fromBelow ? 18 : -18, pointerEvents: 'auto' },
        { opacity: 1, y: 0, duration: 0.45, ease: 'power3.out', delay: 0.18 }
      );
    }

    function goTo(next: number) {
      if (next === current) return;

      // Right panel
      slideOut(rightItems[current]);
      slideIn(rightItems[next]);

      // Left icon
      gsap.to(leftIcons[current], { opacity: 0, scale: 0.85, duration: 0.25, ease: 'power2.in' });
      gsap.fromTo(leftIcons[next],
        { opacity: 0, scale: 1.1 },
        { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.4)', delay: 0.2 }
      );

      // Left text
      slideOut(leftTexts[current]);
      slideIn(leftTexts[next]);

      // Dots
      dots.forEach((dot, i) => {
        if (i === next) {
          gsap.to(dot, { width: 20, backgroundColor: DOT_COLORS[next], duration: 0.3 });
        } else {
          gsap.to(dot, { width: 6, backgroundColor: 'rgba(255,255,255,0.15)', duration: 0.3 });
        }
      });

      // Progress bar
      if (progress) {
        gsap.killTweensOf(progress);
        gsap.set(progress, { width: 0, backgroundColor: DOT_COLORS[next] });
        gsap.to(progress, { width: '100%', duration: 5, ease: 'none' });
      }

      startPulse(next);
      current = next;
    }

    function next() {
      goTo((current + 1) % rightItems.length);
      gsap.delayedCall(5, next);
    }

    if (reduced) {
      rightItems.forEach(el => gsap.set(el, { opacity: 1, position: 'relative' }));
      leftIcons.forEach(el  => gsap.set(el, { opacity: 1, position: 'relative' }));
      leftTexts.forEach(el  => gsap.set(el, { opacity: 1, position: 'relative' }));
    } else {
      ScrollTrigger.create({
        trigger: carousel,
        start: 'top 75%',
        once: true,
        onEnter: () => {
          startPulse(0);
          if (progress) {
            gsap.set(progress, { width: 0 });
            gsap.to(progress, { width: '100%', duration: 5, ease: 'none' });
          }
          gsap.delayedCall(5, next);
        },
      });
    }
  }
</script>
