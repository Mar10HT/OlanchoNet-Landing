---
const features = [
  { text: 'Red #1 de fibra óptica del departamento' },
  { text: 'Más de 10 años de experiencia en el mercado' },
  { text: 'Personal profesional y capacitado' },
  { text: 'En constante expansión — +2 municipios en 2024' },
];
---

<section id="porque" class="bg-brand-dark py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-6 items-stretch">

      <!-- Left panel -->
      <div
        class="reveal rounded-2xl p-10 flex flex-col justify-between min-h-[280px]"
        style="background: var(--color-brand-darker);"
      >
        <!-- Network icon with pulse -->
        <div
          class="icon-pulse w-14 h-14 rounded-full flex items-center justify-center"
          style="background: rgba(0,118,187,0.15);"
        >
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="6"  r="3" fill="var(--color-brand-blue)"/>
            <circle cx="4"  cy="22" r="3" fill="var(--color-brand-blue)"/>
            <circle cx="24" cy="22" r="3" fill="var(--color-brand-blue)"/>
            <line x1="14" y1="9"  x2="4"  y2="19" stroke="var(--color-brand-blue)" stroke-width="1.5" stroke-opacity="0.4"/>
            <line x1="14" y1="9"  x2="24" y2="19" stroke="var(--color-brand-blue)" stroke-width="1.5" stroke-opacity="0.4"/>
            <line x1="4"  y1="22" x2="24" y2="22" stroke="var(--color-brand-blue)" stroke-width="1.5" stroke-opacity="0.4"/>
          </svg>
        </div>

        <div class="mt-8">
          <h3 class="font-display font-black text-3xl text-white leading-tight mb-3">
            La red más avanzada de Olancho
          </h3>
          <p class="text-sm" style="color: rgba(255,255,255,0.4);">Fibra óptica de última generación</p>
        </div>
      </div>

      <!-- Right panel -->
      <div class="reveal reveal-d1 flex flex-col justify-center py-4 lg:pl-8">
        <h2 class="font-display font-black text-4xl lg:text-5xl text-white tracking-tight mb-10">
          ¿Por qué elegirnos?
        </h2>

        <div class="flex flex-col gap-5">
          {features.map((f, i) => (
            <div
              class="feature-item flex items-center gap-4"
              style={`--delay: ${100 + i * 120}ms;`}
            >
              <span
                class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-[11px] font-bold"
                style={`background: ${i % 2 === 0 ? 'rgba(0,118,187,0.15)' : 'rgba(78,182,72,0.15)'}; color: ${i % 2 === 0 ? 'var(--color-brand-blue)' : 'var(--color-brand-green)'};`}
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="text-white/80 text-sm font-medium leading-snug">{f.text}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Feature items: hidden until parent reveals, then stagger in */
  .feature-item {
    opacity: 0;
    transform: translateY(12px);
  }
  .reveal.is-visible .feature-item {
    animation: feat-in 0.55s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0ms) both;
  }
  @keyframes feat-in {
    to { opacity: 1; transform: none; }
  }

  /* Icon subtle pulse ring */
  .icon-pulse {
    animation: icon-ping 3s ease-out infinite;
  }
  @keyframes icon-ping {
    0%, 100% { box-shadow: 0 0 0 0   rgba(0, 118, 187, 0.35); }
    50%       { box-shadow: 0 0 0 10px rgba(0, 118, 187, 0);   }
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-item { opacity: 1; transform: none; }
    .reveal.is-visible .feature-item { animation: none; }
    .icon-pulse { animation: none; }
  }
</style>
