---
interface Props {
  activePage?: 'home' | 'carreras';
}
const { activePage = 'home' } = Astro.props;
---

<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-transparent="true"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          id="nav-logo"
          src="/images/logo-white.svg"
          alt="OlanchoNet"
          width="222"
          height="40"
          class="h-10 transition-all duration-300"
        />
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8">
        {activePage === 'home' && (
          <>
            <a href="#servicios" class="nav-link text-white/80 hover:text-white text-sm font-medium tracking-wide transition-colors">Servicios</a>
            <a href="#planes" class="nav-link text-white/80 hover:text-white text-sm font-medium tracking-wide transition-colors">Planes</a>
            <a href="#nosotros" class="nav-link text-white/80 hover:text-white text-sm font-medium tracking-wide transition-colors">Nosotros</a>
            <a href="#cobertura" class="nav-link text-white/80 hover:text-white text-sm font-medium tracking-wide transition-colors">Cobertura</a>
            <a href="#contacto" class="nav-link text-white/80 hover:text-white text-sm font-medium tracking-wide transition-colors">Contacto</a>
          </>
        )}
        {activePage === 'carreras' && (
          <a href="/" class="nav-link text-white/80 hover:text-white text-sm font-medium tracking-wide transition-colors">← Inicio</a>
        )}
        <a
          href="/carreras"
          class="ml-2 px-5 py-2 border border-white/40 text-white text-sm font-medium tracking-wide rounded hover:bg-white hover:text-brand-blue transition-all duration-200"
        >
          Carreras
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="md:hidden text-white p-3"
        aria-label="Abrir menú"
      >
        <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-brand-dark border-t border-white/10">
    <div class="px-6 py-4 flex flex-col gap-4">
      {activePage === 'home' && (
        <>
          <a href="#servicios" class="mobile-link text-white/80 hover:text-white py-2 text-sm font-medium tracking-wide transition-colors">Servicios</a>
          <a href="#planes" class="mobile-link text-white/80 hover:text-white py-2 text-sm font-medium tracking-wide transition-colors">Planes</a>
          <a href="#nosotros" class="mobile-link text-white/80 hover:text-white py-2 text-sm font-medium tracking-wide transition-colors">Nosotros</a>
          <a href="#cobertura" class="mobile-link text-white/80 hover:text-white py-2 text-sm font-medium tracking-wide transition-colors">Cobertura</a>
          <a href="#contacto" class="mobile-link text-white/80 hover:text-white py-2 text-sm font-medium tracking-wide transition-colors">Contacto</a>
        </>
      )}
      {activePage === 'carreras' && (
        <a href="/" class="text-white/80 hover:text-white py-2 text-sm font-medium tracking-wide transition-colors">← Inicio</a>
      )}
      <a
        href="/carreras"
        class="px-5 py-2.5 border border-white/40 text-white text-sm font-medium tracking-wide rounded text-center hover:bg-white hover:text-brand-blue transition-all duration-200"
      >
        Carreras
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav')!;
  const logo = document.getElementById('nav-logo') as HTMLImageElement;
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  function updateNav() {
    const scrolled = window.scrollY > 60;
    if (scrolled) {
      nav.classList.add('bg-brand-dark', 'shadow-lg');
      nav.setAttribute('data-transparent', 'false');
    } else {
      nav.classList.remove('bg-brand-dark', 'shadow-lg');
      nav.setAttribute('data-transparent', 'true');
    }
  }

  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
