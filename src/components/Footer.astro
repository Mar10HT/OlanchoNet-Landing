---
const year = new Date().getFullYear();
---

<footer class="bg-brand-dark border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Main footer -->
    <div class="py-16 grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <img
          src="/images/logo-white.svg"
          alt="OlanchoNet"
          width="222"
          height="40"
          loading="lazy"
          class="h-10 mb-6"
        />
        <p class="text-white/40 text-sm leading-relaxed max-w-xs">
          Proveedor de servicios de Internet en el departamento de Olancho, Honduras.
        </p>
        <div class="mt-6 flex gap-3">
          <!-- Social placeholder -->
          <button
            type="button"
            aria-label="Facebook"
            class="w-11 h-11 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </button>
          <button
            type="button"
            aria-label="WhatsApp"
            class="w-11 h-11 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.561 4.122 1.531 5.85L.061 23.45a.5.5 0 0 0 .612.61l5.684-1.49A11.946 11.946 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.944 9.944 0 0 1-5.337-1.548l-.382-.228-3.965 1.04 1.054-3.847-.25-.396A9.944 9.944 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="text-white/30 text-xs font-semibold tracking-widest uppercase mb-5">Navegación</p>
        <ul class="space-y-3">
          <li><a href="#servicios" class="text-white/60 text-sm hover:text-white transition-colors">Servicios</a></li>
          <li><a href="#nosotros" class="text-white/60 text-sm hover:text-white transition-colors">Nosotros</a></li>
          <li><a href="#cobertura" class="text-white/60 text-sm hover:text-white transition-colors">Cobertura</a></li>
          <li><a href="#contacto" class="text-white/60 text-sm hover:text-white transition-colors">Contacto</a></li>
          <li><a href="/carreras" class="text-white/60 text-sm hover:text-white transition-colors">Carreras</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-white/30 text-xs font-semibold tracking-widest uppercase mb-5">Contacto</p>
        <ul class="space-y-3">
          <li>
            <a href="tel:+50427854010" class="text-white/60 text-sm hover:text-white transition-colors">+504 2785-4010</a>
          </li>
          <li>
            <a href="tel:+50495015187" class="text-white/60 text-sm hover:text-white transition-colors">+504 9501-5187</a>
          </li>
          <li>
            <a href="mailto:soporte@olanchonet.com" class="text-white/60 text-sm hover:text-white transition-colors">soporte@olanchonet.com</a>
          </li>
          <li>
            <a href="mailto:ventas@olanchonet.com" class="text-white/60 text-sm hover:text-white transition-colors">ventas@olanchonet.com</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/25 text-xs">
        &copy; {year} Olancho Networks. Todos los derechos reservados.
      </p>
      <p class="text-white/15 text-xs">
        Olancho, Honduras
      </p>
    </div>
  </div>
</footer>
