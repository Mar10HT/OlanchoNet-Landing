---
const plans = [
  { name: 'Básico',  mbps: 50,  price: '650',   popular: false },
  { name: 'Hogar',   mbps: 80,  price: '810',   popular: true  },
  { name: 'Plus',    mbps: 120, price: '1,010', popular: false },
  { name: 'Premium', mbps: 180, price: '1,260', popular: false },
  { name: 'Ultra',   mbps: 270, price: '1,580', popular: false },
];

const baseFeatures = [
  'CATV incluido',
  'IPTV incluido',
  'Instalación incluida',
  'Soporte técnico local',
];
---

<section id="planes" class="py-24 lg:py-32" style="background: var(--color-brand-darker);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="reveal flex flex-col items-center text-center mb-12 gap-4">
      <span
        class="inline-flex items-center px-3.5 py-1 rounded-full text-xs font-bold tracking-widest uppercase"
        style="background: rgba(78,182,72,0.12); color: var(--color-brand-green);"
      >
        Planes residenciales
      </span>
      <h2 class="font-display font-black text-4xl lg:text-5xl text-white tracking-tight">
        Internet para todos
      </h2>
      <p class="text-white/50 text-sm max-w-md leading-relaxed">
        CATV e IPTV incluidos en todos los planes. Haz click en una carta para ver los detalles.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="reveal reveal-d1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
      {plans.map((plan) => (
        <div
          class="flip-card cursor-pointer h-[380px]"
          role="button"
          tabindex="0"
          aria-label={`Plan ${plan.name}, ${plan.mbps} Mbps, L ${plan.price} por mes`}
        >
          <div class="flip-card-inner">

            <!-- Front face -->
            <div
              class="flip-card-front rounded-2xl flex flex-col justify-between p-6"
              style={plan.popular
                ? 'background: #081628; box-shadow: inset 0 0 0 2px var(--color-brand-blue);'
                : 'background: #0D1421; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.07);'}
            >
              <!-- Plan name + popular badge -->
              <div class="flex items-center justify-between">
                <span class="text-[11px] font-bold tracking-[0.15em] text-white/50 uppercase">
                  {plan.name}
                </span>
                {plan.popular && (
                  <span
                    class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                    style="background: rgba(78,182,72,0.18); color: var(--color-brand-green);"
                  >
                    Más popular
                  </span>
                )}
              </div>

              <!-- Mbps number -->
              <div class="flex flex-col items-center gap-1">
                <span class="font-display font-black text-[80px] leading-none text-white select-none">
                  {plan.mbps}
                </span>
                <span class="text-[11px] tracking-[0.25em] text-white/35 uppercase">Mbps</span>
              </div>

              <!-- Price + hint -->
              <div class="flex flex-col gap-1.5">
                <span class="font-display font-bold text-[22px] text-white">
                  L {plan.price} <span class="text-sm font-normal text-white/50">/mes</span>
                </span>
                <span class="text-[11px] text-white/25">Haz click para ver detalles →</span>
              </div>
            </div>

            <!-- Back face -->
            <div
              class="flip-card-back rounded-2xl flex flex-col justify-between p-6"
              style="background: var(--color-brand-blue);"
            >
              <!-- Plan label -->
              <div>
                <p class="text-[11px] font-bold tracking-[0.15em] text-white/70 uppercase mb-5">
                  {plan.name} · {plan.mbps} Mbps
                </p>

                <!-- Features -->
                <ul class="flex flex-col gap-2.5">
                  <li class="flex items-center gap-2 text-[13px] text-white">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
                      <circle cx="7" cy="7" r="7" fill="rgba(255,255,255,0.2)"/>
                      <path d="M4 7l2 2 4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {plan.mbps} Mbps de velocidad
                  </li>
                  {baseFeatures.map((feature) => (
                    <li class="flex items-center gap-2 text-[13px] text-white">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
                        <circle cx="7" cy="7" r="7" fill="rgba(255,255,255,0.2)"/>
                        <path d="M4 7l2 2 4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Price + CTA -->
              <div class="flex flex-col gap-3">
                <span class="font-display font-black text-[22px] text-white">
                  L {plan.price} <span class="text-sm font-normal text-white/70">/mes</span>
                </span>
                <a
                  href="#contacto"
                  class="flex items-center justify-center h-10 rounded-lg bg-white text-[13px] font-bold transition-opacity hover:opacity-90"
                  style="color: var(--color-brand-blue);"
                >
                  Contratar
                </a>
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.flip-card').forEach((card) => {
    function toggle() {
      card.classList.toggle('flipped');
    }
    card.addEventListener('click', toggle);
    card.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') {
        ke.preventDefault();
        toggle();
      }
    });
  });
</script>
