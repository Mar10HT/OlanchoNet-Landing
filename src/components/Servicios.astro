---
---

<section id="servicios" class="py-24 lg:py-32 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header split -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-12 lg:mb-14">
      <div>
        <p class="text-[#0076BB] text-xs font-semibold tracking-[0.25em] uppercase mb-4">
          Lo que ofrecemos
        </p>
        <h2 class="font-display font-black text-4xl lg:text-5xl text-gray-900 tracking-tight leading-tight max-w-sm">
          Soluciones para cada necesidad
        </h2>
      </div>
      <div class="lg:max-w-xs">
        <p class="text-gray-500 text-sm leading-relaxed mb-5">
          Desde conectividad básica residencial hasta infraestructura empresarial completa, cubrimos todos los niveles tecnológicos de Olancho.
        </p>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 text-[#0076BB] text-sm font-semibold group/link"
        >
          Consultar un plan
          <svg
            width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            class="transition-transform duration-200 group-hover/link:translate-x-1"
          >
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">

      <!-- Row 1: Fibra Empresarial (wide, featured blue) -->
      <div class="lg:col-span-2 rounded-2xl p-8 lg:p-10 min-h-[260px] flex flex-col justify-between group transition-all duration-300 hover:scale-[1.01]"
        style="background: #0076BB;">
        <div>
          <div class="w-10 h-10 text-white/80 mb-6">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <h3 class="font-display font-bold text-2xl text-white tracking-tight mb-3">
            Fibra Empresarial
          </h3>
          <p class="text-white/70 text-sm leading-relaxed">
            Conectividad dedicada para empresas con SLA garantizado, IP fija, ancho de banda simétrico y atención prioritaria 24/7.
          </p>
        </div>
        <span class="inline-flex self-start mt-6 text-xs font-semibold px-3 py-1 rounded-full text-white/90"
          style="background: rgba(255,255,255,0.15);">B2B</span>
      </div>

      <!-- Row 1: Internet Residencial -->
      <div class="rounded-2xl p-7 lg:p-8 min-h-[260px] flex flex-col justify-between bg-white border border-gray-100 group hover:border-gray-200 transition-all duration-300">
        <div>
          <div class="w-9 h-9 mb-6" style="color: #4EB648;">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="font-display font-bold text-lg text-gray-900 tracking-tight mb-2">
            Internet Residencial
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Planes para el hogar con velocidades desde 10 Mbps hasta 100 Mbps. Instalación incluida y soporte local.
          </p>
        </div>
        <span class="inline-flex self-start mt-5 text-xs font-semibold px-2.5 py-1 rounded-full text-[#4EB648]"
          style="background: rgba(78,182,72,0.1);">B2C</span>
      </div>

      <!-- Row 1: IPTV -->
      <div class="rounded-2xl p-7 lg:p-8 min-h-[260px] flex flex-col justify-between bg-white border border-gray-100 group hover:border-gray-200 transition-all duration-300">
        <div>
          <div class="w-9 h-9 mb-6" style="color: #0076BB;">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="14" rx="2"/><line x1="8" y1="22" x2="16" y2="22"/><line x1="12" y1="18" x2="12" y2="22"/></svg>
          </div>
          <h3 class="font-display font-bold text-lg text-gray-900 tracking-tight mb-2">
            IPTV
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Televisión por internet con canales nacionales e internacionales en alta definición y múltiples dispositivos.
          </p>
        </div>
        <span class="inline-flex self-start mt-5 text-xs font-semibold px-2.5 py-1 rounded-full text-[#0076BB]"
          style="background: rgba(0,118,187,0.1);">B2C / B2B</span>
      </div>

      <!-- Row 2: Diseño de Redes (dark) -->
      <div class="rounded-2xl p-7 lg:p-8 min-h-[230px] flex flex-col justify-between group transition-all duration-300"
        style="background: #0d1421;">
        <div>
          <div class="w-9 h-9 mb-6 text-white/60">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </div>
          <h3 class="font-display font-bold text-lg text-white tracking-tight mb-2">
            Diseño de Redes
          </h3>
          <p class="text-white/50 text-sm leading-relaxed">
            Planificación e implementación de infraestructura para empresas y proyectos públicos.
          </p>
        </div>
        <span class="inline-flex self-start mt-5 text-xs font-semibold px-2.5 py-1 rounded-full text-white/50"
          style="background: rgba(255,255,255,0.08);">Consultoría</span>
      </div>

      <!-- Row 2: Instalaciones Eléctricas (wide) -->
      <div class="lg:col-span-2 rounded-2xl p-7 lg:p-8 min-h-[230px] flex flex-col justify-between bg-white border border-gray-100 group hover:border-gray-200 transition-all duration-300">
        <div>
          <div class="w-9 h-9 mb-6" style="color: #0076BB;">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3 class="font-display font-bold text-lg text-gray-900 tracking-tight mb-2">
            Instalaciones Eléctricas
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed max-w-lg">
            Instalación y mantenimiento de infraestructura eléctrica para equipos de telecomunicaciones, torres de antena y centros de datos.
          </p>
        </div>
        <span class="inline-flex self-start mt-5 text-xs font-semibold px-2.5 py-1 rounded-full text-[#0076BB]"
          style="background: rgba(0,118,187,0.1);">Servicio técnico</span>
      </div>

      <!-- Row 2: Enlaces Inalámbricos -->
      <div class="rounded-2xl p-7 lg:p-8 min-h-[230px] flex flex-col justify-between bg-white border border-gray-100 group hover:border-gray-200 transition-all duration-300">
        <div>
          <div class="w-9 h-9 mb-6" style="color: #4EB648;">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M10.54 15.1a6 6 0 0 1 2.92 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg>
          </div>
          <h3 class="font-display font-bold text-lg text-gray-900 tracking-tight mb-2">
            Enlaces Inalámbricos
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Soluciones punto a punto y multipunto para conectar sedes remotas con alta disponibilidad.
          </p>
        </div>
        <span class="inline-flex self-start mt-5 text-xs font-semibold px-2.5 py-1 rounded-full text-[#4EB648]"
          style="background: rgba(78,182,72,0.1);">B2B</span>
      </div>

    </div>
  </div>
</section>
