---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Carreras — OlanchoNet"
  description="Únete al equipo de OlanchoNet. Aplicación espontánea para trabajar en el principal ISP de Olancho, Honduras."
>
  <Nav activePage="carreras" />

  <main class="pt-20">

    <!-- Header section -->
    <section class="bg-brand-dark py-24 lg:py-32">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <h1 class="font-display font-black text-4xl lg:text-6xl text-white tracking-tight leading-tight mb-6">
          Trabaja en OlanchoNet
        </h1>
        <p class="text-white/60 text-lg leading-relaxed max-w-xl mx-auto">
          Somos un equipo apasionado por la tecnología y comprometido con el desarrollo de Olancho. Si quieres formar parte, nos encantaría conocerte.
        </p>
      </div>
    </section>

    <!-- Form section -->
    <section class="py-20 lg:py-28 bg-gray-50">
      <div class="max-w-2xl mx-auto px-6 lg:px-8">

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 lg:p-12">
          <h2 class="font-display font-bold text-2xl text-gray-900 mb-2">Aplicación espontánea</h2>
          <p class="text-gray-500 text-sm mb-8">
            Completa el formulario y nos pondremos en contacto si hay una posición disponible que encaje con tu perfil.
          </p>

          <form class="space-y-6">

            <!-- Nombre -->
            <div>
              <label for="carreras-nombre" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                Nombre completo *
              </label>
              <input
                id="carreras-nombre"
                type="text"
                name="nombre"
                placeholder="Tu nombre completo"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 outline-none transition-all"
                style="focus:border-color: var(--color-brand-blue);"
              />
            </div>

            <!-- Email + Teléfono -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="carreras-email" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                  Correo electrónico *
                </label>
                <input
                  id="carreras-email"
                  type="email"
                  name="email"
                  placeholder="tu@correo.com"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 outline-none transition-all"
                />
              </div>
              <div>
                <label for="carreras-telefono" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                  Teléfono *
                </label>
                <input
                  id="carreras-telefono"
                  type="tel"
                  name="telefono"
                  placeholder="+504 0000-0000"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 outline-none transition-all"
                />
              </div>
            </div>

            <!-- Posición de interés -->
            <div>
              <label for="carreras-posicion" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                Posición de interés
              </label>
              <select
                id="carreras-posicion"
                name="posicion"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm outline-none transition-all bg-white"
              >
                <option value="">Seleccionar área...</option>
                <option>Técnico de instalaciones</option>
                <option>Soporte técnico</option>
                <option>Ventas y atención al cliente</option>
                <option>Administración de redes</option>
                <option>Administración y finanzas</option>
                <option>Electricista</option>
                <option>Otra</option>
              </select>
            </div>

            <!-- CV -->
            <div>
              <label for="carreras-cv" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                Curriculum vitae
              </label>
              <div class="grid grid-cols-1 gap-3">
                <!-- Upload -->
                <div class="relative">
                  <input
                    id="carreras-cv"
                    type="file"
                    name="cv_archivo"
                    accept=".pdf,.doc,.docx"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-500 text-sm outline-none transition-all file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-[var(--color-brand-blue)] hover:file:bg-blue-100 cursor-pointer"
                  />
                </div>
                <div class="flex items-center gap-3">
                  <div class="flex-1 h-px bg-gray-200"></div>
                  <span class="text-gray-400 text-xs">o</span>
                  <div class="flex-1 h-px bg-gray-200"></div>
                </div>
                <input
                  type="url"
                  name="cv_link"
                  placeholder="Link a tu CV (LinkedIn, Google Drive...)"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 outline-none transition-all"
                />
              </div>
            </div>

            <!-- Mensaje -->
            <div>
              <label for="carreras-mensaje" class="block text-xs font-semibold text-gray-500 tracking-wide uppercase mb-2">
                Mensaje (opcional)
              </label>
              <textarea
                id="carreras-mensaje"
                name="mensaje"
                rows="4"
                placeholder="Cuéntanos un poco sobre ti, tu experiencia o por qué quieres trabajar con nosotros..."
                class="w-full px-4 py-3 rounded-lg border border-gray-200 text-gray-800 text-sm placeholder-gray-400 outline-none transition-all resize-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full py-4 text-white font-semibold text-sm tracking-wide rounded-lg transition-all duration-200 hover:opacity-90 hover:shadow-md"
              style="background: var(--color-brand-blue);"
            >
              Enviar aplicación
            </button>

            <p class="text-gray-400 text-xs text-center leading-relaxed">
              Tu información se mantendrá confidencial y solo será utilizada para proceso de selección.
            </p>
          </form>
        </div>

        <!-- Back link -->
        <div class="mt-8 text-center">
          <a
            href="/"
            class="text-gray-400 text-sm hover:text-gray-700 transition-colors"
          >
            ← Volver al inicio
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  input:focus, select:focus, textarea:focus {
    border-color: var(--color-brand-blue);
    box-shadow: 0 0 0 2px rgba(0, 118, 187, 0.15);
  }
</style>
